# ─── Supabase ────────────────────────────────────────────────
# Public (client-safe) — Settings → API in Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SERVER-ONLY. Required by /api/notify-order to read the order row
# bypassing RLS. NEVER prefix with NEXT_PUBLIC_, never import on the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=PeptideResearch.ro <comenzi@peptideresearch.ro>

# ─── Admin gate ──────────────────────────────────────────────
# Server-side check in API routes and middleware. Must match the
# email of the admin user in Supabase Auth.
ADMIN_EMAIL=infopeptideresearch@gmail.com
NEXT_PUBLIC_ADMIN_EMAIL=infopeptideresearch@gmail.com
